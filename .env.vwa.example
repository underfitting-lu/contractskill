# Local/self-hosted example. For the AWS AMI route, use `.env.vwa.ami.example`
# or generate `.env.vwa` with `bash scripts/write_vwa_ami_env.sh`.
VWA_CLASSIFIEDS=http://127.0.0.1:8083
VWA_CLASSIFIEDS_RESET_TOKEN=replace_me
VWA_SHOPPING=http://127.0.0.1:8082
VWA_REDDIT=http://127.0.0.1:8080
VWA_WIKIPEDIA=http://127.0.0.1:8081
VWA_HOMEPAGE=http://127.0.0.1:80

# Optional
# VWA_FULL_RESET=http://127.0.0.1:7565
# OPENAI_API_KEY=replace_me_if_official_evaluator_needs_it
